{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "rootDir": "src",
    "outDir": "scripts",
    "noEmitOnError": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
